# ══════════════════════════════════════════════════════
#  ReMarket Backend — .env.example
#  Bu faylni .env ga nusxalab to'ldiring
# ══════════════════════════════════════════════════════

PORT=5000
NODE_ENV=production

# Murakkab va tasodifiy sir so'z o'ylab toping (kamida 32 belgi)
JWT_SECRET=your_super_secret_jwt_key_here

# PostgreSQL — CLOUD (Neon.tech bepul tier):
# neon.tech → New Project → Connection string (pooled)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ═══════════════════════════════════════════════════
#  FEATURE FLAGS (true/false)
#    false → console rejim (SMS/to'lov real emas)
#    true  → real SMS va to'lov
# ═══════════════════════════════════════════════════
SMS_ENABLED=false
PAYMENT_ENABLED=false
OTP_STRICT=false

# SMS (eskiz.uz) — https://eskiz.uz
# SMS_ENABLED=true bo'lsa SHART
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=your_eskiz_password
SMS_FROM=4546

# Operator to'lov kartasi
OPERATOR_CARD=8600 0000 0000 0000
OPERATOR_NAME=ReMarket Operator

# Frontend Vercel URL (CORS uchun)
CLIENT_URL=https://frontend-353d.vercel.app

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
MINI_APP_URL=https://frontend-353d.vercel.app/
